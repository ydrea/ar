{
  "cli": {
    "version": ">= 20.1.0",
    "appVersionSource": "remote"
  },
  "build": {
    "dev": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "dev",
      "android": {
        "buildType": "apk"
      }
    },
    "prev": {
      "distribution": "internal",
      "channel": "prev",
      "android": {
        "buildType": "apk"
      }
    },
    "prod": {
      "autoIncrement": true,
      "channel": "prod",
      "android": {
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
