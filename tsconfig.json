{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"]
    },
    "types": ["jest", "node", "react-native"]
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "__tests__/**/*.js",
    "__tests__/**/*.ts",
    "__tests__/**/*.tsx",
    "modules/cumquat-native/src/**/*.ts",
    "modules/cumquat-native/specs/**/*.ts",
    "data/**/*.ts",
    "data/**/*.d.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "jest.setup.ts",
    "metro.config.js",
    "jest.config.js"
  ],
  "exclude": [
    "node_modules",
    "admin",
    "BCK",
    "samples",
    "futur_worklets",
    "modules/cumquat-native/build",
    "CALIBRATION.ts"
  ]
}
