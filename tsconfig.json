{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"]
    },
    "types": ["jest", "node", "react-native"]
  },
  "include": [
    "**/*.js",
    "**/*.jsx",
    "**/*.ts",
    "**/*.tsx",
    "metro.config.js",
    "jest.config.js",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "app.config.js",
    "data/types/**/*.d.ts",
    "data/binaryDataLoader.ts"
  ]
}
