  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "dev": "EAS_BUILD_PROFILE=development npx expo start --dev-client --clear --localhost --android",
    "preview": "EAS_BUILD_PROFILE=preview npx expo start --dev-client --clear --localhost --android",
    "prod": "EAS_BUILD_PROFILE=production npx expo start --dev-client --clear --localhost --android",
    "open": "adb shell am start -a android.intent.action.VIEW -d 'exp+ar://expo-development-client/?url=http%3A%2F%2F127.0.0.1%3A8081'",
    "reset": "npx expo start -c --android",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "codegenConfig": {
    "name": "NativeCumquatSpec",
    "type": "modules",
    "jsSrcsDir": "modules/cumquat-native/specs",
    "android": {
      "javaPackageName": "com.cumquat.nativeengine"
    },
    "ios": {
      "modulesProvider": {
        "NativeCumquat": "NativeCumquatModuleProvider"
      }
    }
  },
  "private": true
